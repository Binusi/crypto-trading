# Backend configuration. Copy to `.env` to override.

# Path to the trained model pickle. Defaults to backend/models/latest.pkl.
# MODEL_PATH=models/latest.pkl

# Where the parquet OHLCV cache lives.
# DATA_CACHE_DIR=data_cache

# Comma-separated CORS origins for the Expo dev client. Use "*" for permissive dev.
# CORS_ORIGINS=*
